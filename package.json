{
  "name": "arenatech-app",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@11.0.8",
  "scripts": {
    "predev": "arena-ensure-infra",
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint src",
    "typecheck": "tsc --noEmit",
    "test": "pnpm test:unit",
    "test:unit": "vitest run --exclude=\"**/integration/**\"",
    "test:integration:prepare": "tsx scripts/check-local-postgres.ts && DATABASE_URL=\"postgresql://arenatech:arenatech_local@localhost:5432/arenatech?schema=public\" prisma migrate deploy && DATABASE_URL=\"postgresql://arenatech:arenatech_local@localhost:5432/arenatech?schema=public\" tsx --env-file=.env.local prisma/seed.ts",
    "test:integration": "pnpm test:integration:prepare && vitest run __tests__/integration",
    "test:watch": "vitest --exclude=\"**/integration/**\"",
    "test:e2e": "playwright test",
    "test:e2e:lint": "tsx __tests__/e2e/lint-e2e.ts",
    "db:generate": "prisma generate",
    "db:generate:local": "DATABASE_URL=${DATABASE_URL:-postgresql://dummy:dummy@localhost:5432/dummy} prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:studio": "prisma studio",
    "db:seed": "tsx --env-file=.env.local prisma/seed.ts",
    "db:reset": "prisma migrate reset",
    "prepare": "husky"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.100.1",
    "@auth/prisma-adapter": "^2.11.2",
    "@aws-sdk/client-s3": "^3.1048.0",
    "@hookform/resolvers": "^5.2.2",
    "@marsidev/react-turnstile": "^1.5.3",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@react-pdf/renderer": "^4.5.1",
    "@tanstack/react-query": "^5.100.9",
    "@tanstack/react-table": "^8.21.3",
    "@trpc/client": "^11.17.0",
    "@trpc/server": "^11.17.0",
    "@trpc/tanstack-react-query": "^11.17.0",
    "bcryptjs": "^3.0.3",
    "class-variance-authority": "^0.7.1",
    "cloudinary": "^2.10.0",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.1.0",
    "dotenv": "^17.4.2",
    "ioredis": "^5.10.1",
    "lucide-react": "^1.14.0",
    "next": "16.2.5",
    "next-auth": "5.0.0-beta.31",
    "next-themes": "^0.4.6",
    "node-forge": "^1.4.0",
    "openai": "^6.41.0",
    "otpauth": "^9.5.1",
    "pg": "^8.21.0",
    "qrcode": "^1.5.4",
    "radix-ui": "^1.4.3",
    "react": "19.2.4",
    "react-day-picker": "^9.14.0",
    "react-dom": "19.2.4",
    "react-hook-form": "^7.75.0",
    "sharp": "^0.34.5",
    "sonner": "^2.0.7",
    "superjson": "^2.2.6",
    "tailwind-merge": "^3.5.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/bcryptjs": "^3.0.0",
    "@types/node": "^20",
    "@types/node-forge": "^1.3.14",
    "@types/pg": "^8.20.0",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@typescript-eslint/eslint-plugin": "^8.59.2",
    "@typescript-eslint/parser": "^8.59.2",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.5",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "husky": "^9.1.7",
    "prettier": "^3.8.3",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "prisma": "^7.8.0",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5",
    "typescript-eslint": "^8.59.2",
    "vitest": "^4.1.5"
  }
}
