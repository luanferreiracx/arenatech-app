# LWK DePix Wallet — config. Copie pra .env e preencha.
# docker compose carrega .env automaticamente.

# ── Rede ────────────────────────────────────────────────────────────
NETWORK=mainnet
ESPLORA_URL=https://blockstream.info/liquid/api

# ── Asset DePix (Liquid mainnet) ────────────────────────────────────
# "Decentralized Pix" — issuer depix.info, precision 8.
DEPIX_ASSET_ID=02f22f8d9c76ab41661a2729e4752e2c5d1a263012141b86ea98af5472df5189

# ── Seguranca ───────────────────────────────────────────────────────
# OBRIGATORIO. Chave forte — protege todos os endpoints (header X-API-Key).
API_KEY=

# ── Webhook ─────────────────────────────────────────────────────────
# URL que recebe os depositos detectados (pending + confirmed). Use https.
WEBHOOK_URL=
# Segredo: vai em X-Webhook-Secret E assina o corpo (HMAC-SHA256 em
# X-Signature: sha256=<hex>). O receptor deve validar a assinatura.
WEBHOOK_SECRET=
# Intervalo (segundos) entre verificacoes de novos depositos.
MONITOR_INTERVAL=30
# Confirmacoes on-chain pra considerar deposito final.
CONFIRMATIONS_REQUIRED=2

# ── Hardening ───────────────────────────────────────────────────────
# CSV de origens permitidas no CORS (ex: https://pdv.seudominio.com).
CORS_ORIGINS=http://localhost:5000
# Teto do fee_rate (sat/vB) aceito no /transfer.
FEE_RATE_MAX=1.0
# Monitor de depositos: desabilitado na fase 1 (multi-wallet sem deposito
# ainda). Habilitar (true) na fase 2 quando o monitor varrer por tenant.
MONITOR_ENABLED=false
