#!/usr/bin/env sh
. "$(dirname -- "$0")/_/husky.sh"

# Pre-push hook v3: typecheck + unit tests
# ADR-0035 v2 (2026-06-01): E2E migrado para CI (.github/workflows/ci.yml)

echo "🔍 Pre-push: validação rápida"

# 1. Typecheck (falha cedo)
echo "→ Typecheck..."
pnpm typecheck || {
  echo "❌ Typecheck falhou. Push bloqueado."
  exit 1
}

# 2. Unit tests (Vitest)
echo "→ Unit tests..."
pnpm test || {
  echo "❌ Unit tests falharam. Push bloqueado."
  exit 1
}

echo "✅ Validação local OK. E2E roda em CI."
