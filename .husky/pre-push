# Pre-push hook v3: validacao rapida (~5s).
# Integracoes e E2E completos bloqueiam no GitHub Actions (autoritativo).
# Pre-push local serve so pra pegar erro obvio antes de gastar tempo no CI,
# sem depender de Postgres/seed local.
#
# Para rodar integracoes RLS/auth localmente:
#   pnpm test:integration
# Para rodar e2e local antes do push manualmente:
#   pnpm test:e2e

echo "🔍 Validacao rapida (Prisma Client + typecheck + unit)..."

# 1. Prisma Client atualizado a partir do schema versionado.
# Usa DATABASE_URL do ambiente quando existir; caso contrario, URL dummy suficiente
# para gerar tipos sem depender de Postgres local.
pnpm db:generate:local || {
  echo "❌ Prisma Client falhou ao gerar. Push bloqueado."
  exit 1
}

# 2. Typecheck
pnpm typecheck || {
  echo "❌ Typecheck falhou. Push bloqueado."
  exit 1
}

# 3. Unit tests (Vitest, sem __tests__/integration)
pnpm test:unit || {
  echo "❌ Unit tests falharam. Push bloqueado."
  exit 1
}

echo "✅ Validacao rapida OK. Integracoes/E2E vao rodar no CI."
