#!/usr/bin/env sh
. "$(dirname -- "$0")/_/husky.sh"

# Pre-push hook v3: validacao rapida (~5s).
# E2E completo bloqueia push no GitHub Actions (autoritativo).
# Pre-push local serve so pra pegar erro obvio antes de gastar tempo no CI.
#
# Para rodar e2e local antes do push manualmente:
#   pnpm test:e2e

echo "🔍 Validacao rapida (typecheck + unit)..."

# 1. Typecheck
pnpm typecheck || {
  echo "❌ Typecheck falhou. Push bloqueado."
  exit 1
}

# 2. Unit tests (Vitest)
pnpm test || {
  echo "❌ Unit tests falharam. Push bloqueado."
  exit 1
}

echo "✅ Validacao rapida OK. E2E vai rodar no CI."
