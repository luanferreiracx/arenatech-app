# === App ===
NODE_ENV=production
NEXTAUTH_URL=https://app.arenatechpi.com.br
NEXTAUTH_SECRET=<gerar com openssl rand -base64 32>

# === Database ===
DATABASE_URL=postgresql://arenatech:<senha>@postgres:5432/arenatech
POSTGRES_USER=arenatech
POSTGRES_PASSWORD=<senha-forte>
POSTGRES_DB=arenatech

# === Redis ===
REDIS_URL=redis://:${REDIS_PASSWORD}@redis:6379
REDIS_PASSWORD=<senha-forte>

# === MinIO ===
S3_ENDPOINT=http://minio:9000
S3_ACCESS_KEY=arenatech
S3_SECRET_KEY=<senha-forte>
S3_BUCKET=arenatech-app
S3_REGION=us-east-1
S3_FORCE_PATH_STYLE=true
MINIO_ROOT_USER=arenatech
MINIO_ROOT_PASSWORD=<senha-forte>

# === Email ===
RESEND_API_KEY=<chave-resend>
EMAIL_FROM=noreply@arenatechpi.com.br

# === Super Admin ===
SUPERADMIN_CPF=<cpf-do-dono>
SUPERADMIN_PASSWORD=<senha-forte>

# === Integrações (configurar quando ativar) ===
# NUVEM_FISCAL_CLIENT_ID=
# NUVEM_FISCAL_CLIENT_SECRET=
# NUVEM_FISCAL_AMBIENTE=producao
# EVOLUTION_API_URL=http://127.0.0.1:8085
# EVOLUTION_API_KEY=
# EVOLUTION_INSTANCE_NAME=arena-intranet
# IMEI_API_URL=
# IMEI_API_KEY=
# AUTENTIQUE_API_KEY=
# AUTENTIQUE_SANDBOX=false
# CHATWOOT_URL=
# CHATWOOT_API_TOKEN=
# CHATWOOT_ACCOUNT_ID=
