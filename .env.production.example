# === App ===
NODE_ENV=production
NEXTAUTH_URL=https://app.arenatechpi.com.br
NEXTAUTH_SECRET=<gerar com openssl rand -base64 32>

# === Database ===
DATABASE_URL=postgresql://arenatech:<senha>@postgres:5432/arenatech
POSTGRES_USER=arenatech
POSTGRES_PASSWORD=<senha-forte>
POSTGRES_DB=arenatech

# === Redis ===
REDIS_URL=redis://:${REDIS_PASSWORD}@redis:6379
REDIS_PASSWORD=<senha-forte>

# === MinIO ===
S3_ENDPOINT=http://minio:9000
S3_ACCESS_KEY=arenatech
S3_SECRET_KEY=<senha-forte>
S3_BUCKET=arenatech-app
S3_REGION=us-east-1
S3_FORCE_PATH_STYLE=true
MINIO_ROOT_USER=arenatech
MINIO_ROOT_PASSWORD=<senha-forte>

# === Cloudinary (imagens publicas de produtos/catalogo) ===
PRODUCT_IMAGES_PROVIDER=cloudinary
CLOUDINARY_CLOUD_NAME=<cloud-name>
CLOUDINARY_API_KEY=<api-key>
CLOUDINARY_API_SECRET=<api-secret>
CLOUDINARY_PRODUCT_FOLDER=arenatech

# === Email ===
RESEND_API_KEY=<chave-resend>
EMAIL_FROM=noreply@arenatechpi.com.br

# === Super Admin ===
SUPERADMIN_CPF=<cpf-do-dono>
SUPERADMIN_PASSWORD=<senha-forte>

# === Integrações (configurar quando ativar) ===
# NUVEM_FISCAL_CLIENT_ID=
# NUVEM_FISCAL_CLIENT_SECRET=
# NUVEM_FISCAL_AMBIENTE=producao
# EVOLUTION_API_URL=http://127.0.0.1:8085
# EVOLUTION_API_KEY=
# EVOLUTION_INSTANCE_NAME=arena-intranet
# WHATSAPP_AI_ENABLED=false
# WHATSAPP_AI_WEBHOOK_TOKEN=
# WHATSAPP_AI_EVOLUTION_INSTANCE=arena-cripto
# WHATSAPP_AI_ALLOWED_PHONE=86995423021
# WHATSAPP_AI_TENANT_ID=
# ANTHROPIC_API_KEY=
# ANTHROPIC_BASE_URL=https://claude.powerprofile.com.br
# ANTHROPIC_MODEL=claude-opus-4-8
# IMEI_CHECK_API_KEY=
# IMEI_CHECK_SERVICE_ID=39
# MEUDANFE_API_KEY=
# AUTENTIQUE_API_KEY=
# AUTENTIQUE_SANDBOX=false
# CHATWOOT_URL=
# CHATWOOT_API_TOKEN=
# CHATWOOT_ACCOUNT_ID=

# === Meta WhatsApp Cloud API (DM com clientes) ===
# O codigo aceita tanto WHATSAPP_CLOUD_* (novo) quanto META_WHATSAPP_* (legado Laravel).
# Se ja existe META_WHATSAPP_TOKEN no .env do VPS, nada precisa mudar.
# WHATSAPP_CLOUD_TOKEN=<system-user-token>
# WHATSAPP_CLOUD_PHONE_NUMBER_ID=<phone-number-id>
# WHATSAPP_CLOUD_BUSINESS_ACCOUNT_ID=<waba-id>
# WHATSAPP_CLOUD_API_VERSION=v22.0
