# === App ===
NODE_ENV=development
# Em produção: https://pdvdepix.app
NEXTAUTH_URL=http://localhost:3000
# URL base para links em emails, PDFs e QR codes (gerados server-side).
# Em produção: https://pdvdepix.app
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXTAUTH_SECRET=

# === Super Admin (seed) ===
# Em prod, definir SUPERADMIN_PASSWORD com senha forte (>= 16 chars, mix).
# Gere com: openssl rand -base64 24
# IMPORTANTE: seed em prod rejeita o placeholder "changeme".
SUPERADMIN_CPF=00000000000
SUPERADMIN_PASSWORD=<change-me-required>

# === Database ===
DATABASE_URL=postgresql://arenatech:arenatech_local@localhost:5432/arenatech?schema=public

# === Redis ===
REDIS_URL=redis://localhost:6379

# === MinIO (S3-compatible) ===
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=arenatech
S3_SECRET_KEY=arenatech_local
S3_BUCKET=arenatech-app
S3_REGION=us-east-1
S3_FORCE_PATH_STYLE=true

# === Cloudinary (imagens publicas de produtos/catalogo) ===
# Provider ativo para novos uploads: cloudinary | minio
PRODUCT_IMAGES_PROVIDER=cloudinary
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_PRODUCT_FOLDER=arenatech

# === Email (Resend em prod, Mailhog em dev) ===
RESEND_API_KEY=
# Remetente dos emails transacionais (reset de senha, notificações).
# Domínio Arena Tech intencional: pdvdepix.app é a intranet, emails saem da marca mãe.
# Requer domínio verificado no Resend.
EMAIL_FROM=noreply@arenatechpi.com.br
SMTP_HOST=localhost
SMTP_PORT=1025

# === Autentique (assinatura digital) ===
AUTENTIQUE_API_KEY=
AUTENTIQUE_SANDBOX=true
AUTENTIQUE_EMAIL=

# === DePix / PixPay (depositos PIX) ===
DEPIX_API_KEY=
DEPIX_API_URL=https://api.pixpay.space/v1/deposit
DEPIX_DEPOSIT_STATUS_URL=https://api.pixpay.space/v1/deposit-status
DEPIX_ADDRESS=

# === LiquidX Pro (saques DePix -> PIX) ===
LIQUIDX_API_KEY=
LIQUIDX_API_BASE_URL=https://liquidx.pro/api
LIQUIDX_WITHDRAW_URL=https://liquidx.pro/api/withdraw
LIQUIDX_WITHDRAW_STATUS_URL=https://liquidx.pro/api/withdraw/status

# === LWK (carteira Liquid/DePix multi-tenant — modulo novo) ===
# Servico LWK (ver lwk/). Sem estas vars, o modulo roda em mock (dev).
LWK_API_URL=
LWK_API_KEY=

# === Asaas (cobrança SaaS) ===
ASAAS_API_KEY=
ASAAS_URL=https://sandbox.asaas.com/api/v3
ASAAS_WEBHOOK_TOKEN=

# === Evolution API (WhatsApp) ===
EVOLUTION_API_URL=https://evolutionapi.arenatechpi.com.br
EVOLUTION_API_KEY=
EVOLUTION_INSTANCE_NAME=arena-intranet

# === Agentes IA via WhatsApp/Evolution ===
WHATSAPP_AI_ENABLED=false
WHATSAPP_AI_WEBHOOK_TOKEN=
WHATSAPP_AI_EVOLUTION_INSTANCE=arena-cripto
# Compat legado: usado como assistant se WHATSAPP_AI_ASSISTANT_PHONES vazio.
WHATSAPP_AI_ALLOWED_PHONE=86995423021,8695423021
WHATSAPP_AI_ASSISTANT_PHONES=86995423021,8695423021
WHATSAPP_AI_CODE_PHONES=447782278602
WHATSAPP_AI_TENANT_ID=
WHATSAPP_AI_ASSISTANT_MODEL=claude-opus-4-8
WHATSAPP_AI_CODE_MODEL=claude-opus-4-8
WHATSAPP_AI_CODE_AUTO_RUN=true
WHATSAPP_AI_CLAUDE_BIN=/home/deployer/.local/bin/claude
WHATSAPP_AI_WORKDIR=/home/deployer/arenatech-app
WHATSAPP_AI_EXECUTION_TIMEOUT_MS=900000
WHATSAPP_AI_EXECUTION_MAX_OUTPUT_CHARS=3500
WHATSAPP_AI_ENABLE_IMAGES=false
WHATSAPP_AI_MAX_IMAGES_PER_MESSAGE=1
WHATSAPP_AI_MAX_IMAGE_BYTES=10485760
WHATSAPP_AI_MEDIA_ALLOW_HTTP=false
WHATSAPP_AI_ENABLE_WEB_SEARCH=false
WHATSAPP_AI_WEB_SEARCH_MODE=anthropic
WHATSAPP_AI_WEB_SEARCH_ANTHROPIC_VERSION=web_search_20250305
WHATSAPP_AI_WEB_SEARCH_MAX_USES=5
WHATSAPP_AI_WEB_SEARCH_ALLOWED_DOMAINS=
WHATSAPP_AI_WEB_SEARCH_BLOCKED_DOMAINS=
WHATSAPP_AI_WEB_SEARCH_ALLOW_FALLBACK=false
WHATSAPP_AI_WEB_SEARCH_PROVIDER=
WHATSAPP_AI_MAX_TOOL_ROUNDS=3
TAVILY_API_KEY=

# === Chatwoot (atendimento) ===
CHATWOOT_URL=https://atendimento.arenatechpi.com.br
CHATWOOT_API_TOKEN=
CHATWOOT_ACCOUNT_ID=1
CHATWOOT_BOT_TOKEN=

# === Fiscal NF-e (Nuvem Fiscal ou Focus NFe) ===
# Provedor ativo: nuvem_fiscal | focus_nfe
FISCAL_PROVIDER=nuvem_fiscal
NUVEM_FISCAL_CLIENT_ID=
NUVEM_FISCAL_CLIENT_SECRET=
NUVEM_FISCAL_AMBIENTE=homologacao
FOCUS_NFE_URL=https://homologacao.focusnfe.com.br
FOCUS_NFE_TOKEN=

# === IMEI Check (alpha.imeicheck.com) ===
IMEI_CHECK_API_KEY=
IMEI_CHECK_SERVICE_ID=39

# === Anthropic (Claude — visão do Talison e agente IA pessoal) ===
ANTHROPIC_API_KEY=
# Chave oficial Anthropic usada para server tools (web_search) e imagem/base64.
# Necessária quando ANTHROPIC_BASE_URL aponta para proxy/PowerProfile.
ANTHROPIC_OFFICIAL_API_KEY=
ANTHROPIC_BASE_URL=
ANTHROPIC_MODEL=claude-opus-4-8
ANTHROPIC_VISION_MODEL=claude-haiku-4-5
# Fallback de visão: usado só quando o Haiku falha/não resolve (decisão do dono).
ANTHROPIC_VISION_FALLBACK_MODEL=claude-sonnet-4-6

# === DeepSeek (Talison IA — conversa + tools, OpenAI-compatible) ===
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# === Groq Whisper (Talison — transcrição de áudio do WhatsApp) ===
# Claude não transcreve áudio; usamos Whisper na Groq (OpenAI-compatible).
GROQ_API_KEY=
GROQ_BASE_URL=https://api.groq.com/openai/v1
GROQ_WHISPER_MODEL=whisper-large-v3-turbo
# Modelo barato pra classificar intenção (cliente aguardando vs encerrou) no
# fluxo de espera. Sem GROQ_API_KEY, o fluxo de espera não age (conservador).
GROQ_INTENT_MODEL=openai/gpt-oss-20b

# === Talison (debounce em ms entre balõezinhos do cliente) ===
TALISON_DEBOUNCE_MS=8000
# Base do catálogo público usada no link que o bot envia (já com a busca: /catalog?q=).
TALISON_CATALOG_URL=https://catalogo.arenatechpi.com.br

# === Talison — fluxo de espera/abandono (cron talison-waiting-sweep) ===
# Grupo do WhatsApp avisado quando o cliente fica sem resposta em conversa OPEN.
TALISON_ALERT_GROUP_JID=120363423723270684@g.us
TALISON_ALERT_INSTANCE=arena-cripto
TALISON_ABANDONED_ALERT_MINUTES=10
TALISON_WAIT_MSG_AFTER_MINUTES=20
TALISON_WAIT_MSG_INTERVAL_MINUTES=5
# Máximo de mensagens fixas de espera antes de parar (evita incomodar à toa).
TALISON_WAIT_MSG_MAX=2

# === DirectD (consulta CPF Receita Federal) ===
DIRECTD_TOKEN=

# === MeuDANFE (consulta XML NF-e SEFAZ) ===
MEUDANFE_API_KEY=

# === Instagram <-> Chatwoot Bridge (opcional) ===
IG_APP_ID=
IG_APP_SECRET=
IG_VERIFY_TOKEN=
IG_ACCESS_TOKEN=

# Secret para autenticar chamadas de cron jobs internos.
# Gerar com: openssl rand -hex 32
CRON_SECRET=

# AES-256-GCM key para encriptar certificados digitais .pfx
# Gerar: openssl rand -base64 32
# CRÍTICO - perda da chave torna certificados ilegíveis
PFX_ENCRYPTION_KEY=

# === Cloudflare Turnstile — desafio anti-bot adaptativo no login ===
# Desafio aparece após 3 falhas para o mesmo CPF. Sem as chaves, o login funciona
# normalmente sem captcha (fail-open / dev). Crie um widget em
# https://dash.cloudflare.com → Turnstile, incluindo os domínios de login
# (app.arenatechpi.com.br, pdvdepix.app).
# Site key é pública (vai pro bundle); secret key NUNCA pode vazar.
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# === 2FA (TOTP) ===
# Opt-in: cada usuário ativa em Configurações › Segurança. O segredo é cifrado em
# repouso com chave derivada do NEXTAUTH_SECRET — não há nova chave para gerenciar.
