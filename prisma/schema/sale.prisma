enum SaleStatus {
  DRAFT
  COMPLETED
  CANCELLED
  REFUNDED
  PARTIALLY_REFUNDED
}

model Sale {
  id              String     @id @default(uuid()) @db.Uuid
  tenantId        String     @map("tenant_id") @db.Uuid
  number          String
  customerId      String?    @map("customer_id") @db.Uuid
  // Cliente avulso: paridade Laravel cliente_nome/cliente_telefone (sem cadastro).
  // Quando customerId esta presente, esses campos sao opcionais para historico.
  customerName    String?    @map("customer_name")
  customerPhone   String?    @map("customer_phone")
  sellerId        String     @map("seller_id") @db.Uuid
  status          SaleStatus @default(DRAFT)

  // Origem: venda pode ser pagamento de OS
  serviceOrderId  String?    @map("service_order_id") @db.Uuid
  isOSPayment     Boolean    @default(false) @map("is_os_payment")

  subtotal        Decimal    @default(0) @db.Decimal(10, 2)
  discountType    String?    @map("discount_type")
  discountValue   Decimal    @default(0) @map("discount_value") @db.Decimal(10, 2)
  discountAmount  Decimal    @default(0) @map("discount_amount") @db.Decimal(10, 2)
  totalAmount     Decimal    @default(0) @map("total_amount") @db.Decimal(10, 2)
  // Downgrade: quando upgrade (trade-in) excede o valor da venda, a loja
  // devolve a diferenca ao cliente. Paridade Laravel `valor_devolvido_cliente`.
  refundDueAmount Decimal    @default(0) @map("refund_due_amount") @db.Decimal(10, 2)
  refundDueMethod String?    @map("refund_due_method") // "cash" | "pix"
  // Acrescimo total pago pelo cliente (politica CLIENTE_PAGA) — diferenca
  // entre valor digitado pelo operador e totalAmount.
  surchargeAmount Decimal    @default(0) @map("surcharge_amount") @db.Decimal(10, 2)
  // Taxa total da operadora (politica LOJA_ABSORVE). Paridade Laravel
  // taxa_operadora_valor.
  operatorFeeAmount Decimal  @default(0) @map("operator_fee_amount") @db.Decimal(10, 2)
  // Receita liquida da loja: totalAmount - operatorFeeAmount (loja absorve).
  // Paridade Laravel receita_liquida_loja. Usado no DRE.
  netRevenueAmount Decimal   @default(0) @map("net_revenue_amount") @db.Decimal(10, 2)
  paidAmount      Decimal    @default(0) @map("paid_amount") @db.Decimal(10, 2)
  changeAmount    Decimal    @default(0) @map("change_amount") @db.Decimal(10, 2)

  paymentDetails  Json?      @map("payment_details")

  observations    String?
  discountReason  String?    @map("discount_reason")

  // Assinatura do TERMO DE ENTREGA (Autentique).
  // Em vendas com upgrade, o PDF inclui automaticamente o bloco de
  // responsabilidade pelos aparelhos recebidos — UMA assinatura cobre tudo.
  signatureDocumentId  String?   @map("signature_document_id")
  signatureUrl         String?   @map("signature_url")
  signatureSentAt      DateTime? @map("signature_sent_at")
  signatureSignedAt    DateTime? @map("signature_signed_at")
  physicalSignature    Boolean   @default(false) @map("physical_signature")

  // Recibo
  receiptSent     Boolean    @default(false) @map("receipt_sent")
  receiptSentAt   DateTime?  @map("receipt_sent_at")

  saleDate        DateTime   @default(now()) @map("sale_date")
  cancelledAt     DateTime?  @map("cancelled_at")
  cancelledById   String?    @map("cancelled_by_id") @db.Uuid
  cancellationReason String? @map("cancellation_reason")

  publicLink      String     @unique @map("public_link")

  deletedAt       DateTime?  @map("deleted_at")
  createdAt       DateTime   @default(now()) @map("created_at")
  updatedAt       DateTime   @updatedAt @map("updated_at")

  items           SaleItem[]
  upgrades        SaleUpgrade[]
  documents       SaleDocument[]

  @@unique([tenantId, number])
  @@index([tenantId, status])
  @@index([tenantId, sellerId])
  @@index([tenantId, customerId])
  @@index([tenantId, saleDate])
  @@index([tenantId, serviceOrderId])
  @@index([publicLink])
  @@map("sales")
}

model SaleItem {
  id              String   @id @default(uuid()) @db.Uuid
  tenantId        String   @map("tenant_id") @db.Uuid
  saleId          String   @map("sale_id") @db.Uuid
  productId       String   @map("product_id") @db.Uuid
  // Varicao do produto selecionada (cor, tamanho, etc — produtos com
  // has_variations=true). Null para produtos sem variacao. Paridade Laravel
  // pdv_venda_itens.variacao_id.
  variationId     String?  @map("variation_id") @db.Uuid
  // Unidade especifica selecionada (produtos serializados — controla_imei=true).
  // Null para produtos genericos vendidos por quantidade.
  // Paridade Laravel pdv_venda_itens.estoque_item_id.
  stockItemId     String?  @map("stock_item_id") @db.Uuid
  description     String
  quantity        Int      @default(1)
  unitPrice       Decimal  @map("unit_price") @db.Decimal(10, 2)
  costPrice       Decimal  @default(0) @map("cost_price") @db.Decimal(10, 2)
  discount        Decimal  @default(0) @db.Decimal(10, 2)
  total           Decimal  @db.Decimal(10, 2)
  // Snapshot do aparelho no momento da venda (paridade Laravel
  // pdv_venda_itens). Persistir aqui (em vez de derivar do StockItem)
  // garante que o recibo/garantia continuem corretos mesmo se o StockItem
  // for alterado/removido depois, e cobre dados migrados sem StockItem.
  imei            String?
  serial          String?
  condition       String?
  batteryHealth   Int?     @map("battery_health")
  warrantyMonths  Int?     @map("warranty_months")
  ehUpgrade       Boolean  @default(false) @map("eh_upgrade")
  createdAt       DateTime @default(now()) @map("created_at")

  sale            Sale     @relation(fields: [saleId], references: [id], onDelete: Cascade)

  @@index([stockItemId])
  @@index([tenantId, saleId])
  @@index([tenantId, stockItemId, createdAt])
  @@map("sale_items")
}

/**
 * Upgrade (aparelho de entrada / trade-in) em uma venda.
 * Paridade Laravel `pdv_venda_upgrades`. Quando a venda finaliza, cada upgrade
 * vira um DevicePurchase (compra de aparelho usado da loja).
 */
model SaleUpgrade {
  id                  String   @id @default(uuid()) @db.Uuid
  tenantId            String   @map("tenant_id") @db.Uuid
  saleId              String   @map("sale_id") @db.Uuid
  brand               String?
  model               String
  /** Capacidade do aparelho (ex: "128GB", "256GB"). Opcional. */
  storage             String?
  /** Cor do aparelho (ex: "Preto", "Titanio Natural"). Opcional. */
  color               String?
  imei                String?
  serialNumber        String?  @map("serial_number")
  condition           String   @default("USED") // USED | NEW
  batteryHealth       Int?     @map("battery_health")
  appraisedValue      Decimal  @map("appraised_value") @db.Decimal(10, 2)
  abatedValue         Decimal  @map("abated_value") @db.Decimal(10, 2)
  notes               String?
  // Quando finaliza a venda, vinculamos ao DevicePurchase criado.
  devicePurchaseId    String?  @map("device_purchase_id") @db.Uuid
  createdAt           DateTime @default(now()) @map("created_at")

  sale                Sale     @relation(fields: [saleId], references: [id], onDelete: Cascade)

  @@index([tenantId, saleId])
  @@map("sale_upgrades")
}

/**
 * Audit log de venda — paridade Laravel `pdv_venda_auditorias`.
 * Registra acoes sensíveis: cancel, refund, atualizar data, vincular cliente.
 */
/**
 * Documento emitido a partir de uma venda: recibo, termo de garantia,
 * termo de troca, termo de responsabilidade.
 * Paridade Laravel pdv_termos_recibos. Permite multi-tipo + reenvios +
 * historico independente da flag receiptSent na Sale.
 */
model SaleDocument {
  id                   String   @id @default(uuid()) @db.Uuid
  tenantId             String   @map("tenant_id") @db.Uuid
  saleId               String   @map("sale_id") @db.Uuid
  type                 String   // 'recibo' | 'termo_garantia' | 'termo_troca' | 'termo_responsabilidade'
  recipientName        String?  @map("recipient_name")
  recipientCpf         String?  @map("recipient_cpf")
  recipientPhone       String?  @map("recipient_phone")
  recipientEmail       String?  @map("recipient_email")
  whatsappSent         Boolean  @default(false) @map("whatsapp_sent")
  whatsappSentAt       DateTime? @map("whatsapp_sent_at")
  autentiqueSent       Boolean  @default(false) @map("autentique_sent")
  autentiqueDocumentId String?  @map("autentique_document_id")
  autentiqueLink       String?  @map("autentique_link")
  autentiqueSentAt     DateTime? @map("autentique_sent_at")
  signed               Boolean  @default(false)
  signedAt             DateTime? @map("signed_at")
  publicLink           String   @unique @map("public_link")
  createdAt            DateTime @default(now()) @map("created_at")
  updatedAt            DateTime @updatedAt @map("updated_at")

  sale Sale @relation(fields: [saleId], references: [id], onDelete: Cascade)

  @@index([tenantId, saleId])
  @@index([tenantId, type])
  @@map("sale_documents")
}

model SaleAudit {
  id            String   @id @default(uuid()) @db.Uuid
  tenantId      String   @map("tenant_id") @db.Uuid
  saleId        String   @map("sale_id") @db.Uuid
  userId        String   @map("user_id") @db.Uuid
  action        String   // "cancel" | "refund" | "date_changed" | "customer_linked"
  field         String?
  previousValue String?  @map("previous_value")
  newValue      String?  @map("new_value")
  reason        String?
  createdAt     DateTime @default(now()) @map("created_at")

  @@index([tenantId, saleId])
  @@map("sale_audits")
}
