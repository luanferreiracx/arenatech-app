enum PlanStatus {
  ACTIVE
  INACTIVE
}

model Plan {
  id              String     @id @default(uuid()) @db.Uuid
  name            String
  slug            String     @unique
  description     String?
  monthlyPrice    Decimal    @map("monthly_price") @db.Decimal(10, 2)
  yearlyPrice     Decimal?   @map("yearly_price") @db.Decimal(10, 2)
  maxUsers        Int        @default(5) @map("max_users")
  maxImeiQueries  Int        @default(50) @map("max_imei_queries")
  features        Json?
  status          PlanStatus @default(ACTIVE)
  createdAt       DateTime   @default(now()) @map("created_at")
  updatedAt       DateTime   @updatedAt @map("updated_at")

  subscriptions Subscription[]

  @@map("plans")
}

enum PreRegistrationStatus {
  PENDING
  APPROVED
  REJECTED
}

model PreRegistration {
  id        String  @id @default(uuid()) @db.Uuid
  tradeName String  @map("trade_name")
  legalName String? @map("legal_name")
  cnpj      String?
  ownerName String  @map("owner_name")
  // NO-KYC: pré-cadastro sem documento — `ownerCpf` opcional. KYC legado podia
  // exigir CPF, mas o auto-cadastro passa a ser exclusivo do NO-KYC (ADR 0050);
  // tenant KYC é criado manualmente pelo superadmin, sem pré-cadastro.
  ownerCpf      String?               @map("owner_cpf")
  ownerEmail    String                @map("owner_email")
  ownerPhone    String                @map("owner_phone")
  planId        String?               @map("plan_id") @db.Uuid
  status        PreRegistrationStatus @default(PENDING)
  notes         String?
  reviewedAt    DateTime?             @map("reviewed_at")
  reviewedById  String?               @map("reviewed_by_id") @db.Uuid

  // Campos do fluxo NO-KYC: o próprio interessado define a senha no cadastro
  // (não recebe senha temporária na aprovação) e verifica email + telefone
  // antes de ir para a fila de aprovação. Hash em repouso; timestamps de
  // verificação preenchidos ao consumir o respectivo código (VerificationCode).
  passwordHash    String?   @map("password_hash")
  emailVerifiedAt DateTime? @map("email_verified_at")
  phoneVerifiedAt DateTime? @map("phone_verified_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("pre_registrations")
}
