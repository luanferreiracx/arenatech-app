model Tenant {
  id        String       @id @default(uuid()) @db.Uuid
  slug      String       @unique
  name      String
  cnpj      String?      @unique
  status    TenantStatus @default(PENDING)
  plan      String?
  /// Gate da API externa (ADR 0057): só com isto ligado o admin do tenant pode
  /// emitir/usar API-keys de parceiro. Controlado pelo superadmin.
  apiAccessEnabled Boolean @default(false) @map("api_access_enabled")
  createdAt DateTime     @default(now()) @map("created_at")
  updatedAt DateTime     @updatedAt @map("updated_at")

  users     UserTenant[]

  @@map("tenants")
}

enum TenantStatus {
  PENDING
  ACTIVE
  SUSPENDED
  CANCELLED
}

model User {
  id String @id @default(uuid()) @db.Uuid
  // KYC: usuário de tenant normal loga por CPF (presente). NO-KYC: loga por
  // email, sem CPF (nullable). Unicidade é por índice único PARCIAL
  // (`WHERE cpf IS NOT NULL` / `WHERE email IS NOT NULL`) criado em migration
  // SQL manual — Prisma não expressa `@unique` parcial, então o `@unique` de
  // schema foi removido para não gerar índice total que rejeitaria múltiplos
  // NULLs de forma inconsistente. Ver ADR 0050.
  cpf                String?
  name               String
  email              String?
  phone              String?  // WhatsApp do usuario (tecnico/vendedor) — notificacao automatica de OS atribuida
  passwordHash       String   @map("password_hash")
  mustChangePassword Boolean  @default(false) @map("must_change_password")
  isSuperAdmin       Boolean  @default(false) @map("is_super_admin")

  // 2FA TOTP. O segredo é cifrado em repouso (AES-256-GCM). twoFactorEnabled só
  // vira true após o usuário confirmar um código (enrollment concluído). Backup
  // codes são hashes SHA-256 de uso único.
  twoFactorSecret      String?   @map("two_factor_secret")
  twoFactorEnabled     Boolean   @default(false) @map("two_factor_enabled")
  twoFactorConfirmedAt DateTime? @map("two_factor_confirmed_at")
  twoFactorBackupCodes String[]  @map("two_factor_backup_codes")
  // Último "passo" TOTP (counter = floor(unixtime/30)) já aceito — anti-replay:
  // o mesmo código de 6 dígitos não autoriza 2 operações na mesma janela.
  twoFactorLastUsedCounter BigInt? @map("two_factor_last_used_counter")

  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  tenants             UserTenant[]
  passwordResetTokens PasswordResetToken[]

  @@map("users")
}

/// Códigos de verificação (OTP) de email/telefone no auto-cadastro NO-KYC.
/// Tabela GLOBAL (sem tenant, sem RLS — igual a password_reset_tokens): o
/// usuário/tenant ainda não existe durante o cadastro. O código é guardado como
/// hash SHA-256 (nunca em claro), tem expiração e contador de tentativas. Ver
/// ADR 0050.
model VerificationCode {
  id                String    @id @default(uuid()) @db.Uuid
  /// Alvo verificado: endereço de email ou telefone (E.164/dígitos).
  target            String
  /// Canal de envio do código.
  channel           VerificationChannel
  /// Pré-cadastro associado (o fluxo NO-KYC verifica antes de criar o usuário).
  preRegistrationId String?   @map("pre_registration_id") @db.Uuid
  /// Hash SHA-256 do código (nunca o código em claro).
  codeHash          String    @map("code_hash")
  expiresAt         DateTime  @map("expires_at")
  attempts          Int       @default(0)
  consumedAt        DateTime? @map("consumed_at")
  createdAt         DateTime  @default(now()) @map("created_at")

  @@index([target, channel])
  @@index([preRegistrationId])
  @@index([expiresAt])
  @@map("verification_codes")
}

enum VerificationChannel {
  EMAIL
  WHATSAPP
}

model UserTenant {
  userId    String   @map("user_id") @db.Uuid
  tenantId  String   @map("tenant_id") @db.Uuid
  // Papel de PRIVILÉGIO no tenant: "admin" (máximo no tenant) ou "operator".
  // Superadmin é flag global em users.is_super_admin (não é papel de tenant).
  role      String   @default("operator")
  // Flags de FUNÇÃO (independentes do privilégio). "Técnico" atua em bancada
  // (paridade Laravel `usuarios.eh_tecnico`); "Caixa" opera o PDV/caixa.
  isTechnician Boolean @default(false) @map("is_technician")
  isCashier    Boolean @default(false) @map("is_cashier")
  createdAt DateTime @default(now()) @map("created_at")

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@id([userId, tenantId])
  @@map("user_tenants")
}

/**
 * Sequencias numericas por tenant + scope (sale, service_order, etc).
 * Substitui a logica "findFirst max + parseInt + +1" sujeita a race
 * condition. Acesso via `nextTenantNumber(tx, tenantId, scope, prefix)`
 * que faz INSERT ... ON CONFLICT UPDATE atomico.
 */
model TenantNumberSequence {
  tenantId String   @map("tenant_id") @db.Uuid
  scope    String   // "sale" | "service_order" | "quick_sale" | ...
  year     Int
  value    Int      @default(0)
  updatedAt DateTime @updatedAt @map("updated_at")

  @@id([tenantId, scope, year])
  @@map("tenant_number_sequences")
}
