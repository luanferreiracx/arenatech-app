enum CustomerType {
  PF
  PJ
}

model Customer {
  id         String       @id @default(uuid()) @db.Uuid
  tenantId   String       @map("tenant_id") @db.Uuid
  type       CustomerType @default(PF)
  name       String
  cpf        String?
  cnpj       String?
  email      String?
  phone      String?
  phone2     String?
  birthDate  DateTime? @map("birth_date") @db.Date
  address    Json?
  notes      String?
  consentAt  DateTime?    @map("consent_at")
  deletedAt  DateTime?    @map("deleted_at")
  createdAt  DateTime     @default(now()) @map("created_at")
  updatedAt  DateTime     @updatedAt @map("updated_at")

  interests  CustomerInterest[]

  @@index([tenantId, name])
  @@index([tenantId, cpf])
  @@index([tenantId, cnpj])
  @@index([tenantId, phone])
  @@index([tenantId, deletedAt])
  @@map("customers")
}

enum InterestStatus {
  WAITING
  CONTACTED
  FINISHED
  CANCELLED
}

enum InterestType {
  PURCHASE
  SALE
  TRADE
  REPAIR
}

model CustomerInterest {
  id                 String          @id @default(uuid()) @db.Uuid
  tenantId           String          @map("tenant_id") @db.Uuid
  customerId         String          @map("customer_id") @db.Uuid
  description        String
  product            String?
  estimatedValue     Decimal?        @map("estimated_value") @db.Decimal(10, 2)
  status             InterestStatus  @default(WAITING)
  interestType       InterestType    @default(PURCHASE) @map("interest_type")
  priority           String          @default("media")
  assignedUserId     String?         @map("assigned_user_id") @db.Uuid
  notes              String?
  followUpAt         DateTime?       @map("follow_up_at")
  resolved           Boolean         @default(false)
  statusChangeReason String?         @map("status_change_reason")
  deletedAt          DateTime?       @map("deleted_at")
  createdAt          DateTime        @default(now()) @map("created_at")
  updatedAt          DateTime        @updatedAt @map("updated_at")

  customer           Customer        @relation(fields: [customerId], references: [id], onDelete: Cascade)
  interactions       InterestInteraction[]

  @@index([tenantId, customerId])
  @@index([tenantId, status])
  @@index([tenantId, interestType])
  @@index([tenantId, followUpAt])
  @@map("customer_interests")
}

model InterestInteraction {
  id              String   @id @default(uuid()) @db.Uuid
  tenantId        String   @map("tenant_id") @db.Uuid
  interestId      String   @map("interest_id") @db.Uuid
  interactionType String   @map("interaction_type")
  description     String
  userId          String   @map("user_id") @db.Uuid
  createdAt       DateTime @default(now()) @map("created_at")

  interest        CustomerInterest @relation(fields: [interestId], references: [id], onDelete: Cascade)

  @@index([tenantId, interestId])
  @@map("interest_interactions")
}
