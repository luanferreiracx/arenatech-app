// ─── Customer module (SPEC v1.0) ───────────────────────────────────
// ADR 0005: PF+PJ unified model
// ADR 0006: Soft delete via deletedAt
// ADR 0007: Address as separate fields
// ADR 0008: RBAC (operator/manager/owner)

enum CustomerType {
  PF
  PJ
}

model Customer {
  id             String       @id @default(uuid()) @db.Uuid
  tenantId       String       @map("tenant_id") @db.Uuid
  type           CustomerType @default(PF)
  cpf            String?      @db.VarChar(11)
  cnpj           String?      @db.VarChar(14)
  name           String       @db.VarChar(255)
  tradeName      String?      @map("trade_name") @db.VarChar(255)
  birthDate      DateTime?    @map("birth_date") @db.Date
  phone          String       @db.VarChar(20)
  phoneSecondary String?      @map("phone_secondary") @db.VarChar(20)
  email          String?      @db.VarChar(255)
  zipCode        String?      @map("zip_code") @db.VarChar(9)
  street         String?      @db.VarChar(255)
  streetNumber   String?      @map("street_number") @db.VarChar(20)
  complement     String?      @db.VarChar(100)
  neighborhood   String?      @db.VarChar(100)
  city           String?      @db.VarChar(100)
  state          String?      @db.VarChar(2)
  notes          String?      @db.Text
  // Opt-out de comunicacoes (LGPD). Quando true, sendMessage falha
  // com mensagem clara antes de chamar provider.
  unsubscribed   Boolean      @default(false)
  unsubscribedAt DateTime?    @map("unsubscribed_at")
  createdById    String?      @map("created_by_id") @db.Uuid
  deletedAt      DateTime?    @map("deleted_at")
  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")

  // Partial unique indexes defined via raw SQL migration (Prisma cannot express WHERE clause)
  // See: 20260515_rls_customers migration
  @@index([tenantId, name])
  @@index([tenantId, phone])
  @@index([tenantId, deletedAt])
  @@map("customers")
}

// ─── Interest (Lead) — autonomous entity, no FK to Customer (Q3) ───

enum InterestType {
  PURCHASE
  SALE
  TRADE
  REPAIR
}

enum InterestStatus {
  WAITING
  CONTACTED
  COMPLETED
  CANCELLED
}

model Interest {
  id           String         @id @default(uuid()) @db.Uuid
  tenantId     String         @map("tenant_id") @db.Uuid
  customerName String         @map("customer_name") @db.VarChar(150)
  phone        String?        @db.VarChar(20)
  cpf          String?        @db.VarChar(14)
  email        String?        @db.VarChar(255)
  type         InterestType   @default(PURCHASE)
  desiredModel String?        @map("desired_model") @db.VarChar(200)
  notes        String?        @db.Text
  status       InterestStatus @default(WAITING)
  createdById  String?        @map("created_by_id") @db.Uuid
  createdAt    DateTime       @default(now()) @map("created_at")
  updatedAt    DateTime       @updatedAt @map("updated_at")

  interactions InterestInteraction[]

  @@index([tenantId, status])
  @@index([tenantId, type])
  @@index([tenantId, customerName])
  @@map("interests")
}

// ─── Interest Interaction ──────────────────────────────────────────

enum InteractionType {
  PHONE
  WHATSAPP
  IN_STORE
}

model InterestInteraction {
  id          String          @id @default(uuid()) @db.Uuid
  tenantId    String          @map("tenant_id") @db.Uuid
  interestId  String          @map("interest_id") @db.Uuid
  userId      String?         @map("user_id") @db.Uuid
  type        InteractionType
  description String          @db.Text
  occurredAt  DateTime        @default(now()) @map("occurred_at")

  interest Interest @relation(fields: [interestId], references: [id], onDelete: Cascade)

  @@index([tenantId, interestId])
  @@map("interest_interactions")
}
