model Service {
  id            String    @id @default(uuid()) @db.Uuid
  tenantId      String    @map("tenant_id") @db.Uuid
  name          String
  serviceType   String?   @map("service_type")
  deviceModel   String?   @map("device_model")
  description   String?
  basePrice     Decimal   @map("base_price") @db.Decimal(10, 2)
  estimatedTime String?   @map("estimated_time")
  active        Boolean   @default(true)
  deletedAt   DateTime? @map("deleted_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  @@index([tenantId, active])
  @@index([tenantId, name])
  @@index([tenantId, serviceType])
  @@map("services")
}

model DiagnosticTemplate {
  id        String    @id @default(uuid()) @db.Uuid
  tenantId  String    @map("tenant_id") @db.Uuid
  title     String
  content   String
  category  String?
  active    Boolean   @default(true)
  deletedAt DateTime? @map("deleted_at")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  @@index([tenantId, active])
  @@map("diagnostic_templates")
}

model DeviceCategory {
  id        String   @id @default(uuid()) @db.Uuid
  tenantId  String   @map("tenant_id") @db.Uuid
  name      String
  createdAt DateTime @default(now()) @map("created_at")

  devices   Device[]

  @@unique([tenantId, name])
  @@index([tenantId])
  @@map("device_categories")
}

model Device {
  id          String    @id @default(uuid()) @db.Uuid
  tenantId    String    @map("tenant_id") @db.Uuid
  categoryId  String?   @map("category_id") @db.Uuid
  brand       String
  model       String
  attributes  Json?
  active      Boolean   @default(true)
  deletedAt   DateTime? @map("deleted_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  category    DeviceCategory? @relation(fields: [categoryId], references: [id])

  @@index([tenantId, brand])
  @@index([tenantId, active])
  @@map("devices")
}

model ServiceObservation {
  id              String    @id @default(uuid()) @db.Uuid
  tenantId        String    @map("tenant_id") @db.Uuid
  title           String
  observation     String
  serviceTypes    Json?     @map("service_types")
  deviceModels    Json?     @map("device_models")
  active          Boolean   @default(true)
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  @@index([tenantId, active])
  @@map("service_observations")
}
