model ServiceType {
  id        String    @id @default(uuid()) @db.Uuid
  tenantId  String    @map("tenant_id") @db.Uuid
  name      String
  slug      String
  active    Boolean   @default(true)
  deletedAt DateTime? @map("deleted_at")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  services Service[]

  @@unique([tenantId, slug])
  @@index([tenantId, active])
  @@map("service_types")
}

model Service {
  id            String       @id @default(uuid()) @db.Uuid
  tenantId      String       @map("tenant_id") @db.Uuid
  serviceTypeId String?      @map("service_type_id") @db.Uuid
  serviceType   String?      @map("service_type")
  deviceModel   String?      @map("device_model")
  name          String
  description   String?
  basePrice     Decimal      @map("base_price") @db.Decimal(10, 2)
  estimatedTime String?      @map("estimated_time")
  active        Boolean      @default(true)
  deletedAt     DateTime?    @map("deleted_at")
  createdAt     DateTime     @default(now()) @map("created_at")
  updatedAt     DateTime     @updatedAt @map("updated_at")

  serviceTypeRef ServiceType? @relation(fields: [serviceTypeId], references: [id])

  @@index([tenantId, active])
  @@index([tenantId, name])
  @@index([tenantId, serviceType])
  @@index([tenantId, serviceTypeId])
  @@map("services")
}

model ServiceObservation {
  id              String    @id @default(uuid()) @db.Uuid
  tenantId        String    @map("tenant_id") @db.Uuid
  title           String
  observation     String
  serviceTypes    Json?     @map("service_types")
  deviceModels    Json?     @map("device_models")
  active          Boolean   @default(true)
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  @@index([tenantId, active])
  @@map("service_observations")
}

model CatalogDevice {
  id               String    @id @default(uuid()) @db.Uuid
  tenantId         String    @map("tenant_id") @db.Uuid
  categoryId       String?   @map("category_id") @db.Uuid
  name             String
  condition        String?
  description      String?
  price            Decimal?  @db.Decimal(10, 2)
  promotionalPrice Decimal?  @map("promotional_price") @db.Decimal(10, 2)
  imageUrl         String?   @map("image_url")
  available        Boolean   @default(true)
  featured         Boolean   @default(false)
  order            Int       @default(0)
  priceUpdatedAt   DateTime? @map("price_updated_at")
  deletedAt        DateTime? @map("deleted_at")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")

  category CatalogDeviceCategory? @relation(fields: [categoryId], references: [id])

  @@index([tenantId, available])
  @@index([tenantId, categoryId])
  @@map("catalog_devices")
}

model CatalogDeviceCategory {
  id        String    @id @default(uuid()) @db.Uuid
  tenantId  String    @map("tenant_id") @db.Uuid
  name      String
  slug      String
  order     Int       @default(0)
  deletedAt DateTime? @map("deleted_at")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  devices CatalogDevice[]

  @@unique([tenantId, slug])
  @@index([tenantId])
  @@map("catalog_device_categories")
}
