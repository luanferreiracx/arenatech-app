/// AuditLog — tenant-scoped table used as RLS test subject in Phase 2.
/// Future phases will expand this into a full audit trail.
model AuditLog {
  id        String   @id @default(uuid()) @db.Uuid
  tenantId  String   @map("tenant_id") @db.Uuid
  action    String
  entity    String
  entityId  String?  @map("entity_id")
  payload   Json?
  createdAt DateTime @default(now()) @map("created_at")

  @@index([tenantId])
  @@map("audit_logs")
}
