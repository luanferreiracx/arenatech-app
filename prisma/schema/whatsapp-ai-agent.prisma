/// Agente IA pessoal via WhatsApp/Evolution. Separado do Talison/Chatwoot.
/// Histórico próprio para auditoria e contexto curto do assistente privado.

enum WhatsappAiMessageRole {
  user
  assistant
  system
}

enum WhatsappAiAgentKind {
  assistant
  claude_code
}

enum WhatsappAiExecutionStatus {
  queued
  running
  completed
  failed
  cancelled
  timed_out
}

model WhatsappAiConversation {
  id            String              @id @default(uuid()) @db.Uuid
  tenantId      String              @map("tenant_id") @db.Uuid
  phone         String
  remoteJid     String              @map("remote_jid")
  instanceName  String              @map("instance_name")
  agentKind     WhatsappAiAgentKind @default(assistant) @map("agent_kind")
  paused        Boolean             @default(false)
  model         String?
  lastMessageAt DateTime?           @map("last_message_at")
  createdAt     DateTime            @default(now()) @map("created_at")
  updatedAt     DateTime            @updatedAt @map("updated_at")

  messages      WhatsappAiMessage[]
  executions    WhatsappAiExecution[]

  @@unique([tenantId, instanceName, phone])
  @@index([tenantId, lastMessageAt])
  @@map("whatsapp_ai_conversations")
}

model WhatsappAiMessage {
  id                 String                @id @default(uuid()) @db.Uuid
  tenantId           String                @map("tenant_id") @db.Uuid
  conversationId     String                @map("conversation_id") @db.Uuid
  role               WhatsappAiMessageRole
  content            String                @db.Text
  evolutionMessageId String?               @map("evolution_message_id")
  providerMessageId  String?               @map("provider_message_id")
  metadata           Json?
  createdAt          DateTime              @default(now()) @map("created_at")

  conversation       WhatsappAiConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@unique([tenantId, evolutionMessageId])
  @@index([tenantId, conversationId, createdAt])
  @@map("whatsapp_ai_messages")
}

model WhatsappAiExecution {
  id                String                    @id @default(uuid()) @db.Uuid
  tenantId          String                    @map("tenant_id") @db.Uuid
  conversationId    String                    @map("conversation_id") @db.Uuid
  status            WhatsappAiExecutionStatus @default(queued)
  prompt            String                    @db.Text
  workdir           String
  model             String?
  branchName        String?                   @map("branch_name")
  prUrl             String?                   @map("pr_url")
  runUrl            String?                   @map("run_url")
  resultSummary     String?                   @map("result_summary") @db.Text
  errorMessage      String?                   @map("error_message") @db.Text
  startedAt         DateTime?                 @map("started_at")
  finishedAt        DateTime?                 @map("finished_at")
  createdAt         DateTime                  @default(now()) @map("created_at")
  updatedAt         DateTime                  @updatedAt @map("updated_at")

  conversation      WhatsappAiConversation    @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([tenantId, conversationId, createdAt])
  @@index([tenantId, status, createdAt])
  @@map("whatsapp_ai_executions")
}
