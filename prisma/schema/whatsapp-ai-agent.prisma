/// Agente IA pessoal via WhatsApp/Evolution. Separado do Talison/Chatwoot.
/// Histórico próprio para auditoria e contexto curto do assistente privado.

enum WhatsappAiMessageRole {
  user
  assistant
  system
}

model WhatsappAiConversation {
  id            String              @id @default(uuid()) @db.Uuid
  tenantId      String              @map("tenant_id") @db.Uuid
  phone         String
  remoteJid     String              @map("remote_jid")
  instanceName  String              @map("instance_name")
  lastMessageAt DateTime?           @map("last_message_at")
  createdAt     DateTime            @default(now()) @map("created_at")
  updatedAt     DateTime            @updatedAt @map("updated_at")

  messages      WhatsappAiMessage[]

  @@unique([tenantId, instanceName, phone])
  @@index([tenantId, lastMessageAt])
  @@map("whatsapp_ai_conversations")
}

model WhatsappAiMessage {
  id                 String                @id @default(uuid()) @db.Uuid
  tenantId           String                @map("tenant_id") @db.Uuid
  conversationId     String                @map("conversation_id") @db.Uuid
  role               WhatsappAiMessageRole
  content            String                @db.Text
  evolutionMessageId String?               @map("evolution_message_id")
  providerMessageId  String?               @map("provider_message_id")
  metadata           Json?
  createdAt          DateTime              @default(now()) @map("created_at")

  conversation       WhatsappAiConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@unique([tenantId, evolutionMessageId])
  @@index([tenantId, conversationId, createdAt])
  @@map("whatsapp_ai_messages")
}
