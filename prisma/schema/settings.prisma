model TenantSettings {
  tenantId           String   @id @map("tenant_id") @db.Uuid
  tradeName          String?  @map("trade_name")
  legalName          String?  @map("legal_name")
  cnpj               String?
  ie                 String?
  phone              String?
  email              String?
  address            Json?
  logoUrl            String?  @map("logo_url")
  zipCode            String?  @map("zip_code")
  street             String?
  streetNumber       String?  @map("street_number")
  complement         String?
  neighborhood       String?
  city               String?
  state              String?
  warrantyNewMonths  Int      @default(12) @map("warranty_new_months")
  warrantyUsedMonths Int      @default(3) @map("warranty_used_months")
  businessHours      String?  @map("business_hours")
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  @@map("tenant_settings")
}

model TenantFiscalSettings {
  tenantId             String    @id @map("tenant_id") @db.Uuid
  legalName            String?   @map("legal_name")
  tradeName            String?   @map("trade_name")
  cnpj                 String?
  ie                   String?
  cnae                 String?
  taxRegime            Int       @default(1) @map("tax_regime")
  zipCode              String?   @map("zip_code")
  street               String?
  streetNumber         String?   @map("street_number")
  complement           String?
  neighborhood         String?
  city                 String?
  state                String?
  municipalityCode     String?   @map("municipality_code")
  nfeEnvironment       Int       @default(2) @map("nfe_environment")
  nfeSeries            String    @default("1") @map("nfe_series")
  nfceSeries           String    @default("1") @map("nfce_series")
  defaultCsosn         String?   @default("102") @map("default_csosn")
  // CFOP padrão para itens emitidos sem CFOP explícito (5102=venda mercadoria estado, 6102=interestadual)
  defaultCfop          String?   @default("5102") @map("default_cfop")
  // NCM padrão fallback quando o produto não tiver NCM cadastrado (8517.12.31 = celular)
  defaultNcm           String?   @default("85171231") @map("default_ncm")
  // CSC (Código de Segurança do Contribuinte) — exigido para NFC-e
  cscId                String?   @map("csc_id")
  cscToken             String?   @map("csc_token")
  enabled              Boolean   @default(false)
  autoIssue            Boolean   @default(false) @map("auto_issue")
  certificateUrl       String?   @map("certificate_url")
  certificateIv        String?   @map("certificate_iv") @db.VarChar(24)
  certificateAuthTag   String?   @map("certificate_auth_tag") @db.VarChar(24)
  certificateUploadedAt DateTime? @map("certificate_uploaded_at")
  certificateExpiresAt DateTime?  @map("certificate_expires_at")
  createdAt            DateTime  @default(now()) @map("created_at")
  updatedAt            DateTime  @updatedAt @map("updated_at")

  @@map("tenant_fiscal_settings")
}

model TenantAssistanceSettings {
  tenantId              String   @id @map("tenant_id") @db.Uuid
  // Identidade (paridade Laravel configuracoes_assistencia.{nome_assistencia,cnpj,telefone,email})
  // Usados em cabeçalhos de orçamento WhatsApp/PDF, termos e comunicação ao cliente.
  assistanceName        String?  @map("assistance_name")
  cnpj                  String?
  phone                 String?
  email                 String?
  // Endereço (paridade endereco/cidade/estado/cep)
  address               String?
  city                  String?
  state                 String?
  zipCode               String?  @map("zip_code")
  logoPath              String?  @map("logo_path")
  termsOfService        String?  @map("terms_of_service") @db.Text
  warrantyPolicy        String?  @map("warranty_policy") @db.Text
  businessHours         String?  @map("business_hours")
  // Paridade Laravel `configuracoes_assistencia.parcelas_sem_juros`.
  // Usado nos orcamentos de servico via WhatsApp / PDF.
  installmentsNoInterest Int     @default(12) @map("installments_no_interest")
  // Paridade Laravel `configuracoes_assistencia.desconto_pix` (em pontos percentuais).
  pixDiscount           Decimal  @default(5) @map("pix_discount") @db.Decimal(5, 2)
  // Paridade Laravel `configuracoes_assistencia.validade_avaliacao_dias`.
  // Usado em DeviceValuation/WhatsApp para apresentar a validade da proposta.
  valuationValidityDays Int      @default(7) @map("valuation_validity_days")
  createdAt             DateTime @default(now()) @map("created_at")
  updatedAt             DateTime @updatedAt @map("updated_at")

  @@map("tenant_assistance_settings")
}

model TenantReceivingSettings {
  tenantId               String   @id @map("tenant_id") @db.Uuid
  defaultPolicyDevice    String   @default("CUSTOMER_PAYS") @map("default_policy_device")
  defaultPolicyNonDevice String   @default("STORE_ABSORBS") @map("default_policy_non_device")
  minInstallmentAmount   Int      @default(5000) @map("min_installment_amount")
  requireCpfAbove        Int      @default(50000) @map("require_cpf_above")
  autoCloseTime          String?  @map("auto_close_time")
  monthlySalesGoal       Int?     @map("monthly_sales_goal")
  defaultDasRate         Decimal? @map("default_das_rate") @db.Decimal(5, 2)
  defaultIcmsDiffRate    Decimal? @map("default_icms_diff_rate") @db.Decimal(5, 2)
  createdAt              DateTime @default(now()) @map("created_at")
  updatedAt              DateTime @updatedAt @map("updated_at")

  @@map("tenant_receiving_settings")
}

/// Política de senha + sessão por tenant. Singleton (tenantId é PK).
model TenantSecuritySettings {
  tenantId                  String   @id @map("tenant_id") @db.Uuid
  minPasswordLength         Int      @default(8) @map("min_password_length")
  requireUppercase          Boolean  @default(false) @map("require_uppercase")
  requireNumber             Boolean  @default(true) @map("require_number")
  requireSpecialChar        Boolean  @default(false) @map("require_special_char")
  passwordExpirationDays    Int?     @map("password_expiration_days")
  // Minutos de inatividade até expirar a sessão (null = sem timeout)
  sessionTimeoutMinutes     Int?     @map("session_timeout_minutes")
  // Bloqueio após N tentativas falhas (0 = desabilitado)
  maxFailedLoginAttempts    Int      @default(5) @map("max_failed_login_attempts")
  lockoutMinutes            Int      @default(15) @map("lockout_minutes")
  createdAt                 DateTime @default(now()) @map("created_at")
  updatedAt                 DateTime @updatedAt @map("updated_at")

  @@map("tenant_security_settings")
}

/// Configuração de notificações por evento × canal.
/// Cada linha = (tenantId, event) único. Canais habilitados em colunas.
model NotificationConfig {
  id           String   @id @default(uuid()) @db.Uuid
  tenantId     String   @map("tenant_id") @db.Uuid
  // Evento canônico: OS_CRIADA, OS_PRONTA, OS_ASSINADA, OS_ENTREGUE,
  // VENDA_FINALIZADA, ORCAMENTO_ENVIADO, COBRANCA_VENCIDA, CAIXA_FECHADO etc.
  event        String
  emailEnabled Boolean  @default(false) @map("email_enabled")
  whatsappEnabled Boolean @default(false) @map("whatsapp_enabled")
  // Template opcional (override do default por evento)
  template     String?  @db.Text
  active       Boolean  @default(true)
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@unique([tenantId, event])
  @@index([tenantId, active])
  @@map("notification_configs")
}

model PaymentMethod {
  id              String            @id @default(uuid()) @db.Uuid
  tenantId        String            @map("tenant_id") @db.Uuid
  name            String
  type            PaymentMethodType
  feePercent      Decimal           @default(0) @map("fee_percent") @db.Decimal(5, 2)
  active          Boolean           @default(true)
  acceptsChange   Boolean           @default(false) @map("accepts_change")
  createdAt       DateTime          @default(now()) @map("created_at")
  updatedAt       DateTime          @updatedAt @map("updated_at")

  installmentRules InstallmentRule[]

  @@index([tenantId, active])
  @@map("payment_methods")
}

enum PaymentMethodType {
  CASH
  PIX
  CREDIT_CARD
  DEBIT_CARD
  BANK_TRANSFER
  STORE_CREDIT
  OTHER
}

model InstallmentRule {
  id              String   @id @default(uuid()) @db.Uuid
  paymentMethodId String   @map("payment_method_id") @db.Uuid
  tenantId        String   @map("tenant_id") @db.Uuid
  installments    Int
  feePercent      Decimal  @default(0) @map("fee_percent") @db.Decimal(5, 2)
  minAmount       Decimal  @default(0) @map("min_amount") @db.Decimal(10, 2)
  createdAt       DateTime @default(now()) @map("created_at")

  paymentMethod   PaymentMethod @relation(fields: [paymentMethodId], references: [id], onDelete: Cascade)

  @@unique([paymentMethodId, installments])
  @@index([tenantId])
  @@map("installment_rules")
}

model TenantIntegration {
  id          String              @id @default(uuid()) @db.Uuid
  tenantId    String              @map("tenant_id") @db.Uuid
  provider    IntegrationProvider
  enabled     Boolean             @default(false)
  config      Json?
  createdAt   DateTime            @default(now()) @map("created_at")
  updatedAt   DateTime            @updatedAt @map("updated_at")

  @@unique([tenantId, provider])
  @@index([tenantId])
  @@map("tenant_integrations")
}

enum IntegrationProvider {
  AUTENTIQUE
  DEPIX
  EVOLUTION_WHATSAPP
  CHATWOOT
  NUVEM_FISCAL
  FOCUS_NFE
  IMEI_CHECK
}

model UserRole {
  id          String     @id @default(uuid()) @db.Uuid
  tenantId    String     @map("tenant_id") @db.Uuid
  userId      String     @map("user_id") @db.Uuid
  role        TenantRole @default(OPERATOR)
  createdAt   DateTime   @default(now()) @map("created_at")
  updatedAt   DateTime   @updatedAt @map("updated_at")

  @@unique([tenantId, userId])
  @@index([tenantId])
  @@map("user_roles")
}

enum TenantRole {
  OWNER
  MANAGER
  OPERATOR
  TECHNICIAN
  CASHIER
}
