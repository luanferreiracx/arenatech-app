enum CashSessionCloseType {
  MANUAL
  AUTOMATIC
}

enum CashMovementType {
  SALE
  DEPOSIT
  WITHDRAWAL
  EXPENSE
}

enum CashMovementNature {
  INCOME
  OUTCOME
}

model CashSession {
  id                String                @id @default(uuid()) @db.Uuid
  tenantId          String                @map("tenant_id") @db.Uuid
  userId            String                @map("user_id") @db.Uuid
  initialBalance    Decimal               @default(0) @map("initial_balance") @db.Decimal(10, 2)
  calculatedBalance Decimal?              @map("calculated_balance") @db.Decimal(10, 2)
  declaredBalance   Decimal?              @map("declared_balance") @db.Decimal(10, 2)
  difference        Decimal?              @db.Decimal(10, 2)
  openingNote       String?               @map("opening_note")
  closingNote       String?               @map("closing_note")
  closeType         CashSessionCloseType? @map("close_type")
  closedByUserId    String?               @map("closed_by_user_id") @db.Uuid
  verified          Boolean               @default(false)
  verifiedAt        DateTime?             @map("verified_at")
  verifiedByUserId  String?               @map("verified_by_user_id") @db.Uuid
  verifiedNote      String?               @map("verified_note")
  openedAt          DateTime              @default(now()) @map("opened_at")
  closedAt          DateTime?             @map("closed_at")
  createdAt         DateTime              @default(now()) @map("created_at")
  updatedAt         DateTime              @updatedAt @map("updated_at")

  movements CashMovement[]

  // K5: no máximo 1 sessão ABERTA por usuário/tenant. Enforçado por índice único
  // PARCIAL `cash_sessions_one_open_per_user` (WHERE closed_at IS NULL) criado em
  // migration — um @@unique([tenantId, userId, closedAt]) NÃO funciona aqui porque
  // o Postgres trata NULLs como distintos (dois closed_at NULL passariam).
  @@index([tenantId, userId, openedAt])
  @@index([tenantId, closedAt])
  @@index([tenantId, verified, closeType])
  // B5 (auditoria financeira 2026-07-11): `pendingReviews` filtra verified=false
  // + closedAt not null e ORDENA por closedAt; sem closedAt no índice o Postgres
  // ordenava em memória todos os pendentes do tenant a cada página.
  @@index([tenantId, verified, closedAt])
  @@map("cash_sessions")
}

model CashMovement {
  id              String              @id @default(uuid()) @db.Uuid
  tenantId        String              @map("tenant_id") @db.Uuid
  cashSessionId   String              @map("cash_session_id") @db.Uuid
  type            CashMovementType
  nature          CashMovementNature
  amount          Decimal             @db.Decimal(10, 2)
  paymentMethod   String?             @map("payment_method")
  paymentMethodId String?             @map("payment_method_id") @db.Uuid
  description     String?
  referenceType   String?             @map("reference_type")
  referenceId     String?             @map("reference_id") @db.Uuid
  createdByUserId String              @map("created_by_user_id") @db.Uuid
  createdAt       DateTime            @default(now()) @map("created_at")

  cashSession CashSession @relation(fields: [cashSessionId], references: [id])

  @@index([tenantId, cashSessionId, createdAt])
  @@index([tenantId, type, createdAt])
  @@index([tenantId, paymentMethod, createdAt])
  @@index([tenantId, referenceType, referenceId])
  @@map("cash_movements")
}
