model Product {
  id               String    @id @default(uuid()) @db.Uuid
  tenantId         String    @map("tenant_id") @db.Uuid
  categoryId       String?   @map("category_id") @db.Uuid
  sku              String?
  barcode          String?
  name             String
  description      String?   @db.Text
  brand            String?
  ncm              String?
  cest             String?
  isSerialized     Boolean   @default(false) @map("is_serialized")
  isPremium        Boolean   @default(false) @map("is_premium")
  // Paridade Laravel `eh_aparelho` — controla quais produtos entram em fluxos
  // especiais (compra de aparelho seminovo, iPhone Hunter, valuation).
  isDevice         Boolean   @default(false) @map("is_device")
  hasVariations    Boolean   @default(false) @map("has_variations")
  icmsDifferentialRate Decimal? @map("icms_differential_rate") @db.Decimal(5, 2)
  costPrice        Decimal   @default(0) @map("cost_price") @db.Decimal(10, 2)
  salePrice        Decimal   @default(0) @map("sale_price") @db.Decimal(10, 2)
  promotionalPrice Decimal?  @map("promotional_price") @db.Decimal(10, 2)
  defaultMargin    Decimal?  @map("default_margin") @db.Decimal(5, 2)
  // Persistido apenas para produtos não-serializados (isSerialized=false).
  // Para isSerialized=true, quantidade disponível é computed via count(StockItem.status=AVAILABLE).
  currentStock     Int       @default(0) @map("current_stock")
  minStock         Int       @default(0) @map("min_stock")
  unit             String    @default("un")
  imageUrl         String?   @map("image_url")
  active           Boolean   @default(true)
  deletedAt        DateTime? @map("deleted_at")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")

  category         ProductCategory?       @relation(fields: [categoryId], references: [id])
  categories       ProductCategoryPivot[]
  photos           ProductPhoto[]
  variations       ProductVariation[]
  attributeConfigs ProductAttributeConfig[]
  movements        StockMovement[]
  purchases        DevicePurchase[]
  stockItems       StockItem[]

  @@index([tenantId, active])
  @@index([tenantId, sku])
  @@index([tenantId, barcode])
  @@index([tenantId, name])
  @@index([tenantId, categoryId])
  @@index([tenantId, brand])
  @@map("products")
}

model ProductCategory {
  id          String    @id @default(uuid()) @db.Uuid
  tenantId    String    @map("tenant_id") @db.Uuid
  name        String
  description String?
  badgeColor  String    @default("#6c757d") @map("badge_color")
  active      Boolean   @default(true)
  deletedAt   DateTime? @map("deleted_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  products    Product[]
  pivots      ProductCategoryPivot[]

  @@unique([tenantId, name])
  @@index([tenantId])
  @@map("product_categories")
}

model ProductCategoryPivot {
  id         String  @id @default(uuid()) @db.Uuid
  tenantId   String  @map("tenant_id") @db.Uuid
  productId  String  @map("product_id") @db.Uuid
  categoryId String  @map("category_id") @db.Uuid
  isPrimary  Boolean @default(false) @map("is_primary")

  product  Product         @relation(fields: [productId], references: [id], onDelete: Cascade)
  category ProductCategory @relation(fields: [categoryId], references: [id])

  @@unique([productId, categoryId])
  @@index([categoryId])
  @@index([tenantId])
  @@map("product_category_pivots")
}

model ProductAttribute {
  id        String    @id @default(uuid()) @db.Uuid
  tenantId  String    @map("tenant_id") @db.Uuid
  name      String
  slug      String
  order     Int       @default(0)
  active    Boolean   @default(true)
  deletedAt DateTime? @map("deleted_at")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  values         ProductAttributeValue[]
  productConfigs ProductAttributeConfig[]

  @@unique([tenantId, slug])
  @@index([tenantId, active])
  @@map("product_attributes")
}

model ProductAttributeValue {
  id           String    @id @default(uuid()) @db.Uuid
  tenantId     String    @map("tenant_id") @db.Uuid
  attributeId  String    @map("attribute_id") @db.Uuid
  value        String
  displayValue String?   @map("display_value")
  code         String?
  order        Int       @default(0)
  active       Boolean   @default(true)
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  attribute  ProductAttribute            @relation(fields: [attributeId], references: [id], onDelete: Cascade)
  variations ProductVariationAttribute[]

  @@unique([attributeId, value])
  @@index([tenantId, attributeId])
  @@map("product_attribute_values")
}

model ProductVariation {
  id               String    @id @default(uuid()) @db.Uuid
  tenantId         String    @map("tenant_id") @db.Uuid
  productId        String    @map("product_id") @db.Uuid
  sku              String?
  barcode          String?
  costPrice        Decimal?  @map("cost_price") @db.Decimal(10, 2)
  salePrice        Decimal?  @map("sale_price") @db.Decimal(10, 2)
  promotionalPrice Decimal?  @map("promotional_price") @db.Decimal(10, 2)
  minStock         Int       @default(0) @map("min_stock")
  imageUrl         String?   @map("image_url")
  active           Boolean   @default(true)
  deletedAt        DateTime? @map("deleted_at")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")

  product         Product                    @relation(fields: [productId], references: [id], onDelete: Cascade)
  attributeValues ProductVariationAttribute[]
  stockItems      StockItem[]

  @@index([tenantId, productId])
  @@index([tenantId, sku])
  @@map("product_variations")
}

model ProductVariationAttribute {
  id               String @id @default(uuid()) @db.Uuid
  variationId      String @map("variation_id") @db.Uuid
  attributeValueId String @map("attribute_value_id") @db.Uuid

  variation      ProductVariation      @relation(fields: [variationId], references: [id], onDelete: Cascade)
  attributeValue ProductAttributeValue @relation(fields: [attributeValueId], references: [id])

  @@unique([variationId, attributeValueId])
  @@map("product_variation_attributes")
}

model ProductAttributeConfig {
  id          String @id @default(uuid()) @db.Uuid
  productId   String @map("product_id") @db.Uuid
  attributeId String @map("attribute_id") @db.Uuid
  order       Int    @default(0)

  product   Product          @relation(fields: [productId], references: [id], onDelete: Cascade)
  attribute ProductAttribute @relation(fields: [attributeId], references: [id])

  @@unique([productId, attributeId])
  @@map("product_attribute_configs")
}

model ProductPhoto {
  id        String   @id @default(uuid()) @db.Uuid
  tenantId  String   @map("tenant_id") @db.Uuid
  productId String   @map("product_id") @db.Uuid
  url       String
  thumbUrl  String?  @map("thumb_url")
  mediumUrl String?  @map("medium_url")
  order     Int      @default(0)
  isPrimary Boolean  @default(false) @map("is_primary")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([tenantId, productId, order])
  @@index([tenantId, productId, isPrimary])
  @@map("product_photos")
}

enum SupplierType {
  PF
  PJ
}

model Supplier {
  id           String       @id @default(uuid()) @db.Uuid
  tenantId     String       @map("tenant_id") @db.Uuid
  type         SupplierType @default(PJ)
  name         String
  tradeName    String?      @map("trade_name")
  cpf          String?
  cnpj         String?
  phone        String?
  email        String?
  zipCode      String?      @map("zip_code")
  street       String?
  streetNumber String?      @map("street_number")
  complement   String?
  neighborhood String?
  city         String?
  state        String?
  notes        String?      @db.Text
  active       Boolean      @default(true)
  deletedAt    DateTime?    @map("deleted_at")
  createdAt    DateTime     @default(now()) @map("created_at")
  updatedAt    DateTime     @updatedAt @map("updated_at")

  stockItems   StockItem[]

  @@index([tenantId, active])
  @@index([tenantId, cpf])
  @@index([tenantId, cnpj])
  @@index([tenantId, name])
  @@map("suppliers")
}

enum StockMovementType {
  ENTRY
  EXIT
  ADJUSTMENT
  RESERVE
  RELEASE
}

model StockMovement {
  id             String            @id @default(uuid()) @db.Uuid
  tenantId       String            @map("tenant_id") @db.Uuid
  productId      String            @map("product_id") @db.Uuid
  variationId    String?           @map("variation_id") @db.Uuid
  stockItemId    String?           @map("stock_item_id") @db.Uuid
  type           StockMovementType
  quantity       Int
  quantityBefore Int?              @map("quantity_before")
  quantityAfter  Int?              @map("quantity_after")
  reason         String?
  notes          String?           @db.Text
  referenceType  String?           @map("reference_type")
  referenceId    String?           @map("reference_id") @db.Uuid
  userId         String            @map("user_id") @db.Uuid
  createdAt      DateTime          @default(now()) @map("created_at")

  product Product @relation(fields: [productId], references: [id])

  @@index([tenantId, productId, createdAt])
  @@index([tenantId, stockItemId, createdAt])
  @@index([tenantId, type, createdAt])
  @@map("stock_movements")
}

enum DeviceCondition {
  NEW
  SEMI_NEW
  USED
  DISPLAY
  REFURBISHED
  DEFECTIVE
}

model DevicePurchase {
  id                  String          @id @default(uuid()) @db.Uuid
  tenantId            String          @map("tenant_id") @db.Uuid
  productId           String?         @map("product_id") @db.Uuid
  customerId          String?         @map("customer_id") @db.Uuid
  supplierId          String?         @map("supplier_id") @db.Uuid
  // Tipo do vendedor: "customer" (pessoa fisica) ou "supplier" (fornecedor PJ).
  // Paridade Laravel `compra_aparelhos.tipo_vendedor`.
  sellerType          String          @default("customer") @map("seller_type")
  imei                String?
  serial              String?
  brand               String?
  model               String?
  condition           DeviceCondition @default(USED)
  batteryHealth       Int?            @map("battery_health")
  purchasePrice       Decimal         @map("purchase_price") @db.Decimal(10, 2)
  salePrice           Decimal?        @map("sale_price") @db.Decimal(10, 2)
  notes               String?
  purchaseDate        DateTime        @default(now()) @map("purchase_date")
  cancelledAt         DateTime?       @map("cancelled_at")
  cancellationReason  String?         @map("cancellation_reason")
  // Termo de responsabilidade (paridade Laravel `compra_aparelhos.termo_*`).
  // Pode ser assinado fisicamente OU via Autentique. Sem termo, compra fica
  // "pendente_assinatura" no status — paridade.
  termSigned          Boolean         @default(false) @map("term_signed")
  termSignedAt        DateTime?       @map("term_signed_at")
  termSignedVia       String?         @map("term_signed_via") // "physical" | "autentique"
  termSignedByUserId  String?         @map("term_signed_by_user_id") @db.Uuid
  autentiqueDocumentId String?        @map("autentique_document_id")
  autentiqueLink      String?         @map("autentique_link")
  autentiqueSentAt    DateTime?       @map("autentique_sent_at")
  createdAt           DateTime        @default(now()) @map("created_at")
  updatedAt           DateTime        @updatedAt @map("updated_at")

  product Product? @relation(fields: [productId], references: [id])

  @@index([tenantId, createdAt])
  @@index([tenantId, imei])
  @@index([tenantId, supplierId])
  @@map("device_purchases")
}
