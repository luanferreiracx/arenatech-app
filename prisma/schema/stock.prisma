model Product {
  id           String    @id @default(uuid()) @db.Uuid
  tenantId     String    @map("tenant_id") @db.Uuid
  sku          String?
  barcode      String?
  name         String
  description  String?
  costPrice    Decimal   @default(0) @map("cost_price") @db.Decimal(10, 2)
  salePrice    Decimal   @default(0) @map("sale_price") @db.Decimal(10, 2)
  currentStock Int       @default(0) @map("current_stock")
  minStock     Int       @default(0) @map("min_stock")
  unit         String    @default("un")
  active       Boolean   @default(true)
  categoryId   String?   @map("category_id") @db.Uuid
  deletedAt    DateTime? @map("deleted_at")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  movements StockMovement[]
  purchases DevicePurchase[]
  category  ProductCategory? @relation(fields: [categoryId], references: [id])

  @@index([tenantId, active])
  @@index([tenantId, sku])
  @@index([tenantId, barcode])
  @@index([tenantId, name])
  @@index([tenantId, categoryId])
  @@map("products")
}

model ProductCategory {
  id        String    @id @default(uuid()) @db.Uuid
  tenantId  String    @map("tenant_id") @db.Uuid
  name      String
  deletedAt DateTime? @map("deleted_at")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  products Product[]

  @@unique([tenantId, name])
  @@index([tenantId])
  @@map("product_categories")
}

model Supplier {
  id        String    @id @default(uuid()) @db.Uuid
  tenantId  String    @map("tenant_id") @db.Uuid
  type      String    @default("PJ") // PF or PJ
  name      String                    // razao social or nome
  tradeName String?   @map("trade_name") // nome fantasia
  cpfCnpj   String?   @map("cpf_cnpj")
  phone     String?
  email     String?
  address   Json?
  notes     String?
  active    Boolean   @default(true)
  deletedAt DateTime? @map("deleted_at")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  @@index([tenantId, active])
  @@index([tenantId, cpfCnpj])
  @@index([tenantId, name])
  @@map("suppliers")
}

enum StockMovementType {
  ENTRY
  EXIT
  ADJUSTMENT
  SALE
  RETURN
  TRANSFER
}

model StockMovement {
  id            String            @id @default(uuid()) @db.Uuid
  tenantId      String            @map("tenant_id") @db.Uuid
  productId     String            @map("product_id") @db.Uuid
  type          StockMovementType
  quantity      Int
  unitCost      Decimal?          @map("unit_cost") @db.Decimal(10, 2)
  reason        String?
  referenceId   String?           @map("reference_id") @db.Uuid
  referenceType String?           @map("reference_type")
  userId        String            @map("user_id") @db.Uuid
  createdAt     DateTime          @default(now()) @map("created_at")

  product Product @relation(fields: [productId], references: [id])

  @@index([tenantId, productId])
  @@index([tenantId, createdAt])
  @@map("stock_movements")
}

enum DeviceCondition {
  NEW
  USED
  REFURBISHED
  DEFECTIVE
}

model DevicePurchase {
  id            String          @id @default(uuid()) @db.Uuid
  tenantId      String          @map("tenant_id") @db.Uuid
  productId     String?         @map("product_id") @db.Uuid
  customerId    String?         @map("customer_id") @db.Uuid
  imei          String?
  serial        String?
  brand         String?
  model         String?
  condition      DeviceCondition @default(USED)
  batteryHealth  Int?            @map("battery_health")
  purchasePrice  Decimal         @map("purchase_price") @db.Decimal(10, 2)
  salePrice      Decimal?        @map("sale_price") @db.Decimal(10, 2)
  notes          String?
  createdAt     DateTime        @default(now()) @map("created_at")
  updatedAt     DateTime        @updatedAt @map("updated_at")

  product Product? @relation(fields: [productId], references: [id])

  @@index([tenantId, createdAt])
  @@index([tenantId, imei])
  @@map("device_purchases")
}
