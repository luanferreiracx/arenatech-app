enum TransactionType {
  PAYABLE
  RECEIVABLE
}

enum TransactionStatus {
  PENDING
  PAID
  OVERDUE
  CANCELLED
  PARTIALLY_PAID
  ESTORNADA
}

model FinancialTransaction {
  id               String            @id @default(uuid()) @db.Uuid
  tenantId         String            @map("tenant_id") @db.Uuid
  type             TransactionType
  status           TransactionStatus @default(PENDING)
  description      String
  category         String?
  categoryId       String?           @map("category_id") @db.Uuid
  supplier         String?
  supplierId       String?           @map("supplier_id") @db.Uuid
  customerName     String?           @map("customer_name")
  customerId       String?           @map("customer_id") @db.Uuid
  totalAmount      Decimal           @map("total_amount") @db.Decimal(10, 2)
  paidAmount       Decimal           @default(0) @map("paid_amount") @db.Decimal(10, 2)
  installmentsTotal Int              @default(1) @map("installments_total")
  dueDate          DateTime          @map("due_date")
  emissionDate     DateTime?         @map("emission_date")
  paidAt           DateTime?         @map("paid_at")
  paymentMethod    String?           @map("payment_method")
  paymentMethodId  String?           @map("payment_method_id") @db.Uuid
  // F3: Discriminated union — exactly one of saleId, serviceOrderId, isManual=true
  saleId           String?           @map("sale_id") @db.Uuid
  serviceOrderId   String?           @map("service_order_id") @db.Uuid
  isManual         Boolean           @default(false) @map("is_manual")
  referenceId      String?           @map("reference_id") @db.Uuid
  referenceType    String?           @map("reference_type")
  notes            String?
  cancelledAt      DateTime?         @map("cancelled_at")
  cancelledByUserId String?          @map("cancelled_by_user_id") @db.Uuid
  cancelReason     String?           @map("cancel_reason")
  createdByUserId  String?           @map("created_by_user_id") @db.Uuid
  deletedAt        DateTime?         @map("deleted_at")
  createdAt        DateTime          @default(now()) @map("created_at")
  updatedAt        DateTime          @updatedAt @map("updated_at")

  installments     Installment[]
  financialCategory FinancialCategory? @relation(fields: [categoryId], references: [id])
  supplierEntity    Supplier?          @relation(fields: [supplierId], references: [id])

  @@index([tenantId, type, status])
  @@index([tenantId, supplierId])
  // G2 (auditoria financeira 2026-07-11): `receivables` filtra (type,status) e
  // ORDENA por paidAt; sem paidAt no índice o Postgres ordenava em memória todos
  // os PAID. Cobre também o "recebido no mês" da dashboard.
  @@index([tenantId, type, status, paidAt])
  @@index([tenantId, dueDate])
  @@index([tenantId, customerId])
  @@index([tenantId, saleId])
  @@index([tenantId, serviceOrderId])
  @@index([tenantId, categoryId])
  @@index([tenantId, deletedAt])
  @@map("financial_transactions")
}

model Installment {
  id                String            @id @default(uuid()) @db.Uuid
  tenantId          String            @map("tenant_id") @db.Uuid
  transactionId     String            @map("transaction_id") @db.Uuid
  number            Int
  amount            Decimal           @db.Decimal(10, 2)
  dueDate           DateTime          @map("due_date")
  paidAmount        Decimal           @default(0) @map("paid_amount") @db.Decimal(10, 2)
  paidAt            DateTime?         @map("paid_at")
  paidByUserId      String?           @map("paid_by_user_id") @db.Uuid
  paymentMethod     String?           @map("payment_method")
  notes             String?
  status            TransactionStatus @default(PENDING)
  estornadaAt       DateTime?         @map("estornada_at")
  estornadaByUserId String?           @map("estornada_by_user_id") @db.Uuid
  estornoReason     String?           @map("estorno_reason")
  createdAt         DateTime          @default(now()) @map("created_at")
  updatedAt         DateTime          @updatedAt @map("updated_at")

  transaction FinancialTransaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  payments    InstallmentPayment[]

  @@index([tenantId, transactionId])
  @@index([tenantId, dueDate, status])
  @@index([tenantId, paidAt])
  @@map("installments")
}

/// Razão (ledger) de pagamentos de parcela — FIN-B2 (auditoria financeira
/// 2026-07-11). Uma parcela paga em N vezes/datas perdia informação:
/// `installment.paidAt` guardava só a ÚLTIMA data e o valor cheio caía no mês
/// dela (regime de caixa errado nos meses anteriores). Aqui cada EVENTO de
/// pagamento é uma linha imutável (valor + data + método), fonte correta de
/// "quanto entrou em cada mês". Estornos são linhas de valor NEGATIVO.
model InstallmentPayment {
  id              String   @id @default(uuid()) @db.Uuid
  tenantId        String   @map("tenant_id") @db.Uuid
  installmentId   String   @map("installment_id") @db.Uuid
  transactionId   String   @map("transaction_id") @db.Uuid
  /// Centavos. Positivo = pagamento; negativo = estorno.
  amountCents     Int      @map("amount_cents")
  paymentMethod   String?  @map("payment_method")
  /// Data-caixa do evento (quando o dinheiro entrou/saiu).
  paidAt          DateTime @map("paid_at")
  /// "payment" | "reversal" — origem do lançamento.
  kind            String   @default("payment")
  createdByUserId String?  @map("created_by_user_id") @db.Uuid
  createdAt       DateTime @default(now()) @map("created_at")

  installment Installment @relation(fields: [installmentId], references: [id], onDelete: Cascade)

  @@index([tenantId, paidAt])
  @@index([tenantId, transactionId])
  @@index([installmentId])
  @@map("installment_payments")
}
