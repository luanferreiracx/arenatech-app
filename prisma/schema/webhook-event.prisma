/// Audit log generico de eventos de webhooks (replay protection).
///
/// Garante idempotencia robusta para webhooks que nao tem identificador
/// natural unico no payload — alem do `DepixWebhookEvent` ja existente
/// (especifico pra DePix payment com 2 colunas extras), esse modelo
/// cobre os outros providers.
///
/// Convencoes para `provider`:
///   - "pagbank": charge ID
///   - "depix_withdraw": payload.id
///   - "autentique": event ID (signature.accepted)
///   - "nuvemfiscal": payload.id + evento
///   - "chatwoot": webhook ID / message ID
///   - "evolution": data.key.id (mensagem)
///
/// `eventId` eh um identificador unico do evento conforme o provider.
/// Se um mesmo evento chegar 2x (replay/retry), a constraint unica em
/// (provider, eventId) bloqueia o INSERT — o handler entao trata como
/// idempotente.
model WebhookEvent {
  id              String    @id @default(uuid()) @db.Uuid
  provider        String
  eventId         String    @map("event_id")
  eventType       String?   @map("event_type")
  sourceIp        String?   @map("source_ip")
  signatureValid  Boolean   @default(false) @map("signature_valid")
  payload         Json
  processed       Boolean   @default(false)
  errorMessage    String?   @map("error_message") @db.Text
  createdAt       DateTime  @default(now()) @map("created_at")

  @@unique([provider, eventId])
  @@index([provider, createdAt])
  @@map("webhook_events")
}
